  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Ucli.Contracts/Ucli.Contracts.csproj" />
    <ProjectReference Include="../Tests.Helper/Tests.Helper.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="MackySoft.Text.Vocabularies" />
