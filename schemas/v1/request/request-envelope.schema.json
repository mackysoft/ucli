{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mackysoft.dev/ucli/v1/request/request-envelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "kind": {
                "type": "string",
                "const": "op"
              },
              "id": {
                "type": "string"
              },
              "op": {
                "type": "string"
              },
              "args": {
                "type": "object"
              }
            },
            "required": [
              "kind",
              "id",
              "op",
              "args"
            ]
          },
          {
            "$ref": "edit-dsl.schema.json"
          }
        ]
      }
    }
  },
  "required": [
    "steps"
  ]
}
