{
  "schemaVersion": 1,
  "inputs": {
    "kind": "explicit",
    "buildTarget": "standaloneLinux64",
    "scenes": {
      "source": "editorBuildSettings"
    },
    "options": {
      "development": false
    }
  },
  "runner": {
    "kind": "buildPipeline"
  },
  "policy": {
    "runtime": {
      "allowedExecutionModes": [
        "daemon",
        "oneshot"
      ],
      "allowedEditorModes": [
        "batchmode",
        "gui"
      ]
    },
    "projectMutationMode": "audit"
  }
}
